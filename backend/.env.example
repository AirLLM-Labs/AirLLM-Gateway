# --- Backend service configuration -------------------------------------------
# Copy to backend/.env for local (non-Docker) runs. In Docker these are supplied
# by docker-compose / the root .env.

APP_NAME=AirLLM Gateway
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

HOST=0.0.0.0
PORT=4000

# Postgres connection (any postgres driver scheme is accepted; it is normalised
# to asyncpg for the app and psycopg2 for migrations).
DATABASE_URL=postgresql+asyncpg://airllm:airllm@localhost:5432/airllm

# Shared admin token protecting /admin endpoints and the dashboard proxy.
ADMIN_API_KEY=changeme-admin-key

# Comma-separated allowed CORS origins (the dashboard).
CORS_ORIGINS=http://localhost:3000

# Upstream llama.cpp timeouts (seconds).
UPSTREAM_TIMEOUT=600
HEALTH_TIMEOUT=5
