# ============================================================================
# AirLLM Gateway — root environment (docker compose reads this file)
#
#   cp .env.example .env   # then edit MODEL_DIR + the *_MODEL_FILE names
#   docker compose up -d
# ============================================================================

# --- Compose profiles -------------------------------------------------------
# `models` starts the three GPU llama.cpp servers (coder/vision/deepseek).
# Remove this line for an app-only stack (postgres + backend + dashboard);
# the backend will then only discover model servers you point it at elsewhere.
COMPOSE_PROFILES=models

# --- Ports (host-published) -------------------------------------------------
# Each model container also listens on its own port inside the compose network.
BACKEND_PORT=4000
FRONTEND_PORT=3000
POSTGRES_PORT=5432
CODER_PORT=8080
VISION_PORT=8081
DEEPSEEK_PORT=8082

# --- Models -----------------------------------------------------------------
# Host folder holding your .gguf files; mounted read-only at /models in each
# model container. Use forward slashes on Windows (e.g. D:/model).
MODEL_DIR=D:/model

# GPU layers to offload (99 = offload everything; lower it if you run out of VRAM).
NGL=99

# GGUF filenames inside MODEL_DIR — EDIT to match the files you actually have.
CODER_MODEL_FILE=qwen2.5-coder-7b-instruct-q4_k_m.gguf
VISION_MODEL_FILE=llava-v1.6-mistral-7b.Q4_K_M.gguf
VISION_MMPROJ_FILE=mmproj-model-f16.gguf
DEEPSEEK_MODEL_FILE=DeepSeek-Coder-V2-Lite-Instruct-Q4_K_M.gguf

# Client-facing model ids: what /v1 clients send as "model", and the names the
# backend registers them under during auto-discovery.
CODER_MODEL_NAME=qwen2.5-coder
VISION_MODEL_NAME=llava
DEEPSEEK_MODEL_NAME=deepseek-coder-v2-lite

# Context window per model.
CODER_CTX=8192
VISION_CTX=4096
DEEPSEEK_CTX=16384

# --- Auto-discovery (backend) ----------------------------------------------
# The backend probes the model servers' /health and registers the healthy ones.
MODEL_DISCOVERY_ENABLED=true
MODEL_DISCOVERY_INTERVAL=30   # seconds between discovery passes

# --- Postgres ---------------------------------------------------------------
POSTGRES_USER=airllm
POSTGRES_PASSWORD=airllm
POSTGRES_DB=airllm

# --- Security ---------------------------------------------------------------
# Shared admin token protecting /admin endpoints and the dashboard proxy.
# CHANGE THIS to a long random string for any non-local deployment.
ADMIN_API_KEY=rithul-airllm-admin

# --- App --------------------------------------------------------------------
# Allowed CORS origins for the gateway (the dashboard origin).
CORS_ORIGINS=http://localhost:3000
DEBUG=false
LOG_LEVEL=INFO
