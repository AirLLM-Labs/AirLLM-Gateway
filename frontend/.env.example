# --- Dashboard (Next.js) configuration ---------------------------------------
# Copy to frontend/.env.local for local runs.

# Where the dashboard's server-side proxy reaches the gateway backend.
# Local (no Docker):       http://localhost:4000
# docker-compose network:  http://backend:4000
BACKEND_INTERNAL_URL=http://localhost:4000

# Must match the backend's ADMIN_API_KEY. Used only server-side by the proxy;
# never exposed to the browser.
ADMIN_API_KEY=changeme-admin-key
